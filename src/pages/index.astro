---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineApp</title>
  </head>
  <body>

    <header>
      <h1>🎬 CineApp</h1>
      <p>Descubrí las mejores películas</p>
    </header>

    <main>
      <section id="busqueda">
        <input type="text" placeholder="Buscar película..." />
      </section>

      <section id="filtros">
        <button>Todas</button>
        <button>Acción</button>
        <button>Comedia</button>
        <button>Terror</button>
        <button>Drama</button>
      </section>

      <section id="peliculas">
        <div class="card">
          <img src="https://placehold.co/200x300" alt="Película" />
          <h3>Nombre película</h3>
          <p>⭐ 8.5</p>
        </div>
        <div class="card">
          <img src="https://placehold.co/200x300" alt="Película" />
          <h3>Nombre película</h3>
          <p>⭐ 7.2</p>
        </div>
        <div class="card">
          <img src="https://placehold.co/200x300" alt="Película" />
          <h3>Nombre película</h3>
          <p>⭐ 9.1</p>
        </div>
      </section>
    </main>

    <footer>
    
    </footer>

  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background-color: #0f0f0f;
    color: #ffffff;
    font-family: Arial, sans-serif;
  }

  header {
    background-color: #1a1a2e;
    text-align: center;
    padding: 2rem;
  }

  header h1 {
    font-size: 2.5rem;
  }

  header p {
    color: #aaaaaa;
    margin-top: 0.5rem;
  }

  #busqueda {
    display: flex;
    justify-content: center;
    padding: 2rem;
  }

  #busqueda input {
    width: 100%;
    max-width: 500px;
    padding: 0.8rem 1rem;
    border-radius: 8px;
    border: none;
    font-size: 1rem;
    background-color: #1a1a1a;
    color: white;
    border: 1px solid #444;
  }

  #filtros {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0 2rem 2rem;
  }

  #filtros button {
    padding: 0.5rem 1.2rem;
    border-radius: 20px;
    border: 1px solid #e50914;
    background: transparent;
    color: white;
    cursor: pointer;
    font-size: 0.9rem;
  }

  #filtros button:hover {
    background-color: #e50914;
  }

  #peliculas {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    padding: 2rem;
  }

  .card {
    background-color: #1a1a1a;
    border-radius: 10px;
    overflow: hidden;
    text-align: center;
    transition: transform 0.2s;
  }

  .card:hover {
    transform: scale(1.05);
  }

  .card img {
    width: 100%;
  }

  .card h3 {
    padding: 0.5rem;
    font-size: 0.95rem;
  }

  .card p {
    padding-bottom: 0.8rem;
    color: #f5c518;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: #555;
  }
</style>